{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "allowJs": true
  },
  "include": [
    "server/**/*.ts",
    "api/v2/**/*.ts",
    "api/lib/**/*.js",
    "global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
