    { "source": "/api/ai", "destination": "/api/ai.js" },
    { "source": "/api/draft-email", "destination": "/api/draft-email.js" },
    { "source": "/api/proposal", "destination": "/api/proposal.js" },
    { "source": "/api/crm-update", "destination": "/api/crm-update.js" },
    { "source": "/api/prep", "destination": "/api/prep.js" },
    { "source": "/api/linkedin", "destination": "/api/linkedin.js" },
    { "source": "/api/calendar", "destination": "/api/calendar.js" },
    { "source": "/api/calendar-create", "destination": "/api/calendar-create.js" },
    { "source": "/api/post-call", "destination": "/api/post-call.js" },
    { "source": "/api/slack", "destination": "/api/slack.js" },
    { "source": "/api/granola", "destination": "/api/granola.js" },
    { "source": "/api/intelligence", "destination": "/api/intelligence.js" },
    { "source": "/api/briefing", "destination": "/api/briefing.js" },
    { "source": "/api/sync", "destination": "/api/sync.js" },
    { "source": "/api/pricing", "destination": "/api/pricing.js" },
    { "source": "/api/snapshot", "destination": "/api/snapshot.js" },
    { "source": "/api/end-of-day", "destination": "/api/end-of-day.js" },
    { "source": "/api/end-of-week", "destination": "/api/end-of-week.js" },
    { "source": "/api/google-auth", "destination": "/api/google-auth.js" },
    { "source": "/v2", "destination": "/v2.html" },
    { "source": "/api/v2/command", "destination": "/api/v2/command.ts" },
    { "source": "/api/v2/events", "destination": "/api/v2/events.ts" },
    { "source": "/api/v2/projections", "destination": "/api/v2/projections.ts" },
    { "source": "/api/v2/execution", "destination": "/api/v2/execution.ts" },
    { "source": "/api/v2/scheduling", "destination": "/api/v2/scheduling.ts" },
    { "source": "/api/v2/wizard", "destination": "/api/v2/wizard.ts" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization, Content-Type" }
      ]
    }
  ]
}
